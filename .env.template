# ─── LLM (Gemma via Ollama) ───
OLLAMA_HOST= http://localhost:11434
OLLAMA_MODEL= gemma3:12b

# ─── Qdrant Vector Store ───
QDRANT_URL= http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=pubmed_articles

# ─── PubMed E-utilities ───
# Optional: increases rate limit from 3/sec to 10/sec
NCBI_API_KEY=
NCBI_EMAIL=

# ─── Embedding Model ───
EMBEDDING_MODEL = microsoft/BiomedNLP-BiomedBERT-base-uncased-abstract-fulltext

# ─── App Settings ───
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
